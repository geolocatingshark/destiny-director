DEFAULT_URL="https://kyberscorner.com/"

# Database. MYSQL_PRIVATE_URL is preferred over MYSQL_URL when both are set.
MYSQL_PRIVATE_URL=mysql://username:password@hostname/dbname
MYSQL_URL=mysql://username:password@hostname/dbname
# In case you are using a MYSQL instance without ssl set the below
# MYSQL_SSL=false

# Webserver port (Bungie OAuth callback + rotation editor); defaults to 8080
PORT=8080

# Public origin the anchor web app is reachable at, used to mint rotation-editor links.
# On Railway this is derived from RAILWAY_PUBLIC_DOMAIN automatically; set this only to
# override (e.g. a custom domain). Scheme required; no trailing slash.
# PUBLIC_BASE_URL=https://anchor.example.com

