world_sql_content*
manifest.zip

# Local DB dumps (`make dump-prod-db` / `dump-dev-db`) — but keep Atlas migrations,
# so a new migrations/*.sql isn't silently ignored.
*.sql
!migrations/*.sql

# My ToDo list
ToDo

# VSCode Settings
.vscode/settings.json

# Misc
.swp
ToDo.md
Twitter Keys.txt

# Syncthing
.stfolder/
.stignore
.trash/

# Claude Code sandbox (bubblewrap) phantom mount-points.
# These don't exist on disk; they only appear as /dev/null bind-mounts inside
# the sandbox at runtime. Ignored so `git add -A` can't re-stage them as empty
# blobs. (.mcp.json deliberately not ignored — it's a real project-MCP file.)
.bash_profile
.bashrc
.profile
.zshrc
.zprofile
.gitconfig
.gitmodules
.ripgreprc
.idea
# Ad-hoc investigation scratch (Portal API etc.) — not for commit
scratch/
# Core dumps (crashed-process memory images). Never commit — they contain live
# secrets (bot tokens) lifted from process memory. GitHub push-protection blocks them.
core
core.[0-9]*
